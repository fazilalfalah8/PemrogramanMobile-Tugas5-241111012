<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (Satwalaya Premium) -->
    <style name="Base.Theme.Satwalaya" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Branding colors -->
        <item name="colorPrimary">#554181</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#5BB6BB</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorTertiary">#FF806E</item>

        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Menghilangkan garis pemisah (overlay) default sistem -->
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>

        <!-- Memastikan konten menggantung di bawah status bar tanpa scrim -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
    </style>

    <style name="Theme.Satwalaya" parent="Base.Theme.Satwalaya" />

    <!-- Premium Component Styles -->
    <style name="PremiumCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="PremiumButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingVertical">12dp</item>
    </style>
</resources>